# Copy to .env for local development (this file is committed; .env is NOT).
# Get this connection string from your Neon project dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Optional: restrict which frontend origin may call the API.
# Locally Angular runs on http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# Google OAuth Client ID (the "Web application" client from Google Cloud
# Console). Must match the client_id used by the frontend. Public value.
GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
