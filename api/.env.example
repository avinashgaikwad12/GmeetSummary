# Copy to .env for local development (this file is committed; .env is NOT).
# Get this connection string from your Neon project dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Optional: restrict which frontend origin may call the API.
# Locally Angular runs on http://localhost:4200
CORS_ORIGIN=http://localhost:4200

# Google OAuth Client ID (the "Web application" client from Google Cloud
# Console). Must match the client_id used by the frontend. Public value.
GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com

# Comma-separated list of admin emails. These users see the Admin page and
# can never be blocked from logging in.
ADMIN_EMAILS=you@gmail.com

# Summaries: set ONE of these. Gemini is used if present (free tier), else Claude.
# Google AI Studio key (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
# Anthropic/Claude key (optional fallback): https://console.anthropic.com
ANTHROPIC_API_KEY=
